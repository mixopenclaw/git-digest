# Git Digest Backend — Environment Variables
#
# Copy this file to .env and fill in real values for production.

# Server listen address
GD_ADDR=:8080

# JWT signing secret (REQUIRED in production)
GD_JWT_SECRET=changeme-dev-secret

# Path to SQLite database file
GD_DB_PATH=data/gitdigest.db

# Root directory for artifact storage
GD_STORAGE_ROOT=data/artifacts

# Maximum concurrent scan jobs
GD_JOB_CONCURRENCY=4

# Artifact retention period in days
GD_RETENTION_DAYS=30
